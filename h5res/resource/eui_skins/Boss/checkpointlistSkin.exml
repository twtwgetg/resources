		<e:Image y="0" scaleX="-1" scaleY="1" anchorOffsetX="0" x="510" source="com_twotitlebg1" scale9Grid="7,0,126,78" width="255"/>
	</e:Group>
	<e:Label id="title" text="关卡排名" y="11" size="24" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181B" textColor="0xF2F2E9" horizontalCenter="0"/>
	<e:Group width="510" height="511" y="45" anchorOffsetX="0" anchorOffsetY="0" scaleX="1" scaleY="1" horizontalCenter="0">
		<e:Group y="0" horizontalCenter="0">
			<e:Image width="245" height="223" y="0" source="com_back_down" x="0" scale9Grid="40,40,5,5"/>
			<e:Image width="245" height="223" source="com_back_down" scale9Grid="40,40,5,5" x="490" scaleX="-1"/>
			<e:Image width="245" height="223" source="com_back_down" scale9Grid="40,40,5,5" x="490" scaleX="-1" scaleY="-1" y="446"/>
			<e:Image width="245" height="223" y="446" source="com_back_down" scale9Grid="40,40,5,5" x="0" scaleY="-1"/>
		</e:Group>
		<e:Group y="2" horizontalCenter="-1" anchorOffsetY="0" height="30">
