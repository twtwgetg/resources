		<ns1:checkpointmodel width="470" height="34" x="19" y="50" skinName="checkpointmodelSkin" visible="false"/>
	</e:Group>
	<e:Button id="closeBtn" label="" width="56" height="56" right="2" top="2" scaleX="0.7" scaleY="0.7">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:ogre_ui="ogre_ui.*">
			<e:Image width="56" height="56" y.down="-2" source="com_close"/>
