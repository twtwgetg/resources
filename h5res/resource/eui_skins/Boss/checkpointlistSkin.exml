				<e:Label text="角色名" size="20" scaleX="1" scaleY="1" x="199" y="0" height="20" width="70" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181B" textAlign="center" textColor="0xfbcc90"/>
				<e:Label text="通关数" size="20" scaleX="1" scaleY="1" x="354" y="0" height="20" width="88" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181B" textAlign="center" textColor="0xfbcc90"/>
