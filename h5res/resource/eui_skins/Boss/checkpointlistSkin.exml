			<e:Label text="关卡:" size="20" scaleX="1" scaleY="1" x="318" y="0" height="20" width="60" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181B" textAlign="left" textColor="0xf0e6cd"/>
