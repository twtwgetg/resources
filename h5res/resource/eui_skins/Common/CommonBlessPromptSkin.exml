<?xml version="1.0" encoding="utf-8"?>
<e:Skin  class="CommonBlessPromptSkin" width="485" height="600" xmlns:e="http://ns.egret.com/eui" xmlns:w="http://ns.egret.com/wing">
	<e:Image width="2560" height="2560" source="com_mask" horizontalCenter="0" verticalCenter="-1"/>
	<e:Group x="0" y="0">
