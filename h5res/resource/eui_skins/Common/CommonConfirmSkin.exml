		</e:Skin>
		</e:skinName>
	</e:Button>
	<e:Label id="txt" text="是否花费50元宝兑换1次挑战次数？\n今日剩余兑换次数(4/4)" y="72" anchorOffsetX="0" width="410" anchorOffsetY="0" height="86" size="20" lineSpacing="5" textAlign="center" verticalAlign="middle" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181b" horizontalCenter="0"/>
</e:Skin>