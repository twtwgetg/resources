		<e:Label id="title" text="提 示" y="11" size="24" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181B" horizontalCenter="-3" textColor="0xf2f2e9"/>
	</e:Group>
	<e:Button id="closeBtn" label="" width="56" height="56" scaleX="0.7" scaleY="0.7" right="3" top="4">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:ogre_ui="ogre_ui.*" xmlns:ns1="*">
			<e:Image width="56" height="56" y.down="-2" source="com_close"/>
			<e:Label id="labelDisplay" horizontalCenter="0" verticalCenter="0"/>
		</e:Skin>
		</e:skinName>
	</e:Button>
	<e:Button id="cancel" label="取  消" x="99" y="190" width="104" height="35">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:ns1="*" xmlns:w="http://ns.egret.com/wing">
			<e:Image width="52" y.up="0" y.down="-2" height="35" source="com_button05"/>
	<e:Image height="35" x="104" y="0" width="52" scaleX="-1" y.down="-2" source="com_button05"/>
	<e:Label id="labelDisplay" text="取 消" size="20" y.down="5" stroke="1" strokeColor="0x071E39" horizontalCenter.down="0" y="8" horizontalCenter="0"  fontFamily="Microsoft YaHei"/>
		</e:Skin>
		</e:skinName>
	</e:Button>
	<e:Button id="ok" label="确 定" x="280" y="190" width="104" height="35">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:ns1="*">
			<e:Image width="52" y.up="0" y.down="-2" source="com_button06" height="35"/>
			<e:Image height="35" source="com_button06" x="104" y="0" width="52" scaleX="-1" y.down="-2"/>
