	</e:Button>
	<e:Label text="宝  石" x="281" y="22" size="20" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181b"/>
	<e:Image width="570" height="400" x="16" y="65" scale9Grid="15,17,3,3" source="beibao_pic2"/>
