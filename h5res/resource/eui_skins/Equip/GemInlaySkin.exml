	<e:Group id="nowGroup" x="55" y="490" anchorOffsetX="0" width="503" anchorOffsetY="0" height="115">
		<e:Image width="570" height="155" x="-39" y="-20" scale9Grid="15,17,3,3" source="beibao_pic2" scaleX="1" scaleY="1"/>
		<ns1:ItemBase4 id="curItem" width="100" height="111" x="0" y="0" anchorOffsetX="0" anchorOffsetY="0" skinName="skin.ItemBaseSkin4"/>
