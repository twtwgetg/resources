	<e:Group id="noGemGroup" x="158" y="601">
		<e:Label text="暂无可镶嵌的宝石" y="0" anchorOffsetX="0" width="287" size="18" anchorOffsetY="0" height="30" textColor="0xffffff" textAlign="center" x="0" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181b"/>
	</e:Group>
	<e:Scroller anchorOffsetX="0" anchorOffsetY="0" width="512.67" x="45" height="352.34" y="91">
