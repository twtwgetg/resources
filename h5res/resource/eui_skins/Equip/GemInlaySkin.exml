				<e:Label text="一键合成" includeIn="up" size="20" horizontalCenter="0" y="10" fontFamily="Microsoft YaHei"/>
				<e:Label text="一键合成" includeIn="down" size="20" horizontalCenter="0" y="8" fontFamily="Microsoft YaHei"/>
