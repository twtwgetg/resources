				<e:Image width="100%" height="100%" source="tongyong_btn13" y.up="0" y.down="-2"/>
				<e:Label text="合    成" includeIn="up" size="20" verticalCenter="0" horizontalCenter="0" fontFamily="Microsoft YaHei"/>
				<e:Label text="合    成" includeIn="down" size="20" horizontalCenter="0" y="8" fontFamily="Microsoft YaHei"/>
			</e:Skin>
			</e:skinName>
		</e:Button>
		<e:Button id="allUpgradeBtn" label="" x="380" y="66" width="105" height="41">
			<e:skinName>
			<e:Skin states="up,down,disabled">
