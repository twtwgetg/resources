		<e:List id="gemList" anchorOffsetX="0" x="-1" anchorOffsetY="0" y="-5" touchEnabled="true" touchChildren="true">
			<e:layout>
				<e:TileLayout requestedColumnCount="5" horizontalGap="3"/>
			</e:layout>
		</e:List>
		</e:viewport>
	</e:Scroller>
	<e:Group x="47" y="93" anchorOffsetY="0" height="350" anchorOffsetX="0" width="510" visible="false">
