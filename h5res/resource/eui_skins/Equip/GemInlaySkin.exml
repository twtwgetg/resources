		<e:Label id="curPower" text="战力:33333" x="105" y="28" size="18" textColor="0xecc275" stroke="1" strokeColor="0x14181b" fontFamily="Microsoft YaHei"/>
		<e:Button id="dressBtn" label="" x="380" y="50" width="105" height="41" scaleX="1" scaleY="1">
			<e:skinName>
			<e:Skin states="up,down,disabled">
				<e:Image width="100%" height="100%" y.up="0" y.down="-2" source="tongyong_btn14"/>
				<e:Label text="镶    嵌" includeIn="up" size="20" verticalCenter="0" horizontalCenter="0" fontFamily="Microsoft YaHei"/>
				<e:Label text="镶    嵌" includeIn="down" size="20" horizontalCenter="0" y="8" fontFamily="Microsoft YaHei"/>
			</e:Skin>
			</e:skinName>
		</e:Button>
		<e:Button id="takeOffBtn" label="" x="380" y="50" width="105" height="41" scaleX="1" scaleY="1">
			<e:skinName>
				<e:Skin states="up,down,disabled">
				<e:Image width="100%" height="100%" source="tongyong_btn13" y.down="-2"/>
				<e:Label text="拆    除" includeIn="up" size="20" verticalCenter="0" horizontalCenter="0" fontFamily="Microsoft YaHei"/>
	<e:Label text="拆    除" includeIn="down" size="20" horizontalCenter="0" y="9" fontFamily="Microsoft YaHei"/>
				</e:Skin>
			</e:skinName>
		</e:Button>
		<e:Scroller anchorOffsetX="0" anchorOffsetY="0" width="236.67" x="109" height="60.34" y="55">
