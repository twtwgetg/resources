		</e:Scroller>
		<e:Group x="108" y="47" anchorOffsetY="0" height="59" visible="false">
			<ns1:PropMidBaseSkin2 width="133" height="25" x="0" y="0" skinName="skin.PropMidBase2" scaleX="1" scaleY="1"/>
		</e:Group>
	</e:Group>
	<e:Label id="noNextGemSign" text="当前已达最高等级" y="679" size="18" horizontalCenter="0" textColor="0xf70231" bold="true" fontFamily="Microsoft YaHei" stroke="1" strokeColor="0x14181b"/>

</e:Skin>