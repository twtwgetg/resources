<?xml version="1.0" encoding="utf-8"?>
<e:Skin class="skin.GemInlaySkin" width="610" height="850" xmlns:e="http://ns.egret.com/eui" xmlns:ns1="*" xmlns:w="http://ns.egret.com/wing">
	<e:Image width="300" height="850" x="0" y="10" source="tongyong_pic22" scale9Grid="35,74,1,1"/>
