	<e:Button id="closeBtn" label="" x="565" y="2" width="43" height="43">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:game="ogre_ui.*" xmlns:w="http://ns.egret.com/wing" xmlns:ns1="*" xmlns:tween="egret.tween.*">
			<e:Image width="100%" height="100%" source="tongyong_btn6" y.down="-2"/>
