	<ogre_ui:CopyPanel id="copypanel" width="640" height="1037" x="0" y="0" anchorOffsetX="0" anchorOffsetY="0" skinName="CopyPanel" visible="false"/>
	
	<ns1:RightBar id="rightBar" y="336" anchorOffsetX="0" anchorOffsetY="0" skinName="skin.RightBarSkin" right="0" width="160"/> 
	
	<e:TextInput id="b" width="177.98" height="33" x="496.53" y="274.26" anchorOffsetX="0" anchorOffsetY="0" rotation="0.07"/>
	<e:ProgressBar width="640" height="16" skinName="skins.ExpProgress" anchorOffsetX="0" anchorOffsetY="0" horizontalCenter="0" bottom="0" visible="false"/>
