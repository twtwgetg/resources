	<ns1:SkillBar id="skillBar" width="514" height="99" x="85" y="899" skinName="SkillBarSkin" anchorOffsetX="0" anchorOffsetY="0" visible="false"/>
	<e:Group horizontalCenter="0" bottom="-2">
		<e:Group id="bottomGroup" y="0" horizontalCenter="0">
			<ogre_ui:FunctionBar id="functionBar" anchorOffsetX="0" width="762" height="122" skinName="tFunctionBarSkin" y="0" anchorOffsetY="122" horizontalCenter="0"/>
			<ns1:ExpProgress id="expBar" skinName="skins.ExpProgress" anchorOffsetX="0" anchorOffsetY="0" width="420" x="171" y="-18"/>
		</e:Group>
	</e:Group>
	<ns1:JoyStick id="joystick" x="169" y="449" skinName="ControlrodSkin" anchorOffsetX="0" anchorOffsetY="0"/>
	<e:TextInput id="a" width="179" height="39" x="495" y="219" anchorOffsetX="0" anchorOffsetY="0"/>
	<e:TextInput id="light_wid" width="179" height="31" y="363.02" anchorOffsetX="0" anchorOffsetY="0" skinName="TTextInputSkin" left="13"/>
	<e:TextInput id="light_bright" width="179" height="31" y="405.06" anchorOffsetX="0" anchorOffsetY="0" skinName="TTextInputSkin" left="15"/>
	<e:TextInput id="light_bl" width="179" height="31" y="449.56" anchorOffsetX="0" anchorOffsetY="0" skinName="TTextInputSkin" left="15"/>
