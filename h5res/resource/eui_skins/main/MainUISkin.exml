<?xml version='1.0' encoding='utf-8'?>
<e:Skin class="MainUISkin" xmlns:e="http://ns.egret.com/eui" xmlns:ogre_ui="ogre_ui.*" xmlns:w="http://ns.egret.com/wing" xmlns:ns1="*" xmlns:tween="egret.tween.*" width="795">
	<w:Declarations>
		<tween:TweenGroup id="skillNameTween">
			<tween:TweenItem target="{skillNameGroup}">
				<tween:Set>
					<tween:props>
						<e:Object scaleX="{0.5}" scaleY="{0.5}" x="{254}" y="{529}"/>
					</tween:props>
				</tween:Set>
				<tween:To duration="150">
					<tween:props>
						<e:Object x="{50.5}" y="{385.5}" scaleX="{1.2}" scaleY="{1.2}"/>
					</tween:props>
				</tween:To>
				<tween:To duration="100">
					<tween:props>
						<e:Object x="{-10.4}" y="{316.8}" scaleX="{1.2}" scaleY="{1.2}"/>
					</tween:props>
				</tween:To>
				<tween:To duration="150">
					<tween:props>
						<e:Object alpha="{1}" x="{-51}" y="{271}" scaleX="{0.8}" scaleY="{0.8}"/>
					</tween:props>
				</tween:To>
				<tween:To duration="350">
					<tween:props>
						<e:Object/>
					</tween:props>
				</tween:To>
				<tween:To duration="150">
					<tween:props>
						<e:Object alpha="{0}"/>
					</tween:props>
				</tween:To>
			</tween:TweenItem>
		</tween:TweenGroup>
		<tween:TweenGroup id="buttonmove">
			<tween:TweenItem target="{btnQingQiu}">
				<tween:Set>
					<tween:props>
						<e:Object alpha="{0}" x="{290}"/>
					</tween:props>
				</tween:Set>
				<tween:To duration="50">
					<tween:props>
						<e:Object alpha="{1}" x="{290}"/>
					</tween:props>
				</tween:To>
				<tween:To duration="450" ease="quartIn">
					<tween:props>
						<e:Object x="{185}"/>
					</tween:props>
				</tween:To>
			</tween:TweenItem>
		</tween:TweenGroup>
	</w:Declarations>
	<e:Group horizontalCenter="0" top="0">
		<ogre_ui:RoleInfoBar id="roleinfo" skinName="RoleInfoSkin" anchorOffsetX="0" anchorOffsetY="0" y="0" horizontalCenter="0"/>
