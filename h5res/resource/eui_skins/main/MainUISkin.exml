			<e:Button id="btnQingQiu" label="" x="185" y="2" width="119" height="119">
				<e:skinName>
				<e:Skin states="up,down,disabled" xmlns:ogre_ui="ogre_ui.*">
					<e:Image width="100%" height="100%" y.down="-1" source="DaZuo_but02" source.up="DaZuo_but02" source.down="DaZuo_but02"/>
					<e:Label id="labelDisplay" horizontalCenter="0" text="邀请" size="30" y="69" fontFamily="Microsoft YaHei" stroke="1" horizontalCenter.up="0" y.up="67" y.down="65" textColor="0xd37fdb"/>
				</e:Skin>
				</e:skinName>
			</e:Button>
		</e:Group>
		<e:Group id="daZuoGroup" y="-6" horizontalCenter="44.5" touchEnabled="false">
			<e:Image y="0" x="0" scale9Grid="7,0,99,15" source="DaZuo_Pic01"/>
			<e:Image width="83" height="33" x="134" y="3" source="Dazuo_ingpic" scaleX="1" scaleY="1"/>
			<e:Label text="(10秒)" x="221" y="10" size="18" stroke="1" width="90" anchorOffsetY="0" height="19" fontFamily="Microsoft YaHei" strokeColor="0x14181b" textAlign="left" anchorOffsetX="0" textColor="0xf11d40" visible="false"/>
			<e:Group x="122" y="41">
				<e:Label text="获得经验:" x="21" size="18" stroke="1" textAlign="left" fontFamily="Microsoft YaHei" textColor="0xF2F2E9" strokeColor="0x14181B" y="0"/>
				<e:Label id="shuangXiuExp" text="0" size="18" stroke="1" textAlign="left" width="90" fontFamily="Microsoft YaHei" strokeColor="0x14181B" x="103" y="0" textColor="0x1ce17d"/>
			</e:Group>
			<e:Group x="122" y="67" height="25">
				<e:Label text="获得真气:" x="21" size="18" stroke="1" textAlign="left" fontFamily="Microsoft YaHei" textColor="0xF2F2E9" strokeColor="0x14181B" y="0"/>
				<e:Label id="shuangXiuZhenQi" text="0" size="18" stroke="1" textAlign="left" width="133" fontFamily="Microsoft YaHei" strokeColor="0x14181B" x="103" y="0" anchorOffsetX="0" anchorOffsetY="0" height="18" textColor="0x1ce17d"/>
			</e:Group>
			<e:Group x="143" y="92" anchorOffsetX="0" width="181" anchorOffsetY="0" height="19">
				<e:Label text="今日剩余次数:" x="0" size="18" stroke="1" textAlign="left" fontFamily="Microsoft YaHei" textColor="0xF2F2E9" strokeColor="0x14181B" y="-2"/>
				<e:Label id="shuangXiuRemainTimes" text="9" size="18" stroke="1" textAlign="left" width="101" fontFamily="Microsoft YaHei" strokeColor="0x14181B" x="120" y="-2" anchorOffsetX="0" anchorOffsetY="0" height="20" textColor="0x1ce17d"/>
			</e:Group>
			<e:Image id="shuangXiuCircle" scaleX="1" scaleY="1" fillMode="clip" x="14" source="DaZuo_Pic02" width="104" height="104" y="8"/>
			<e:Label id="remainTimesLbl" text="" y="8" size="24" stroke="1" width="85" anchorOffsetY="0" height="24" fontFamily="Microsoft YaHei" strokeColor="0x14181B" textAlign="left" anchorOffsetX="0" textColor="0xf11d40" horizontalCenter="80.5"/>
