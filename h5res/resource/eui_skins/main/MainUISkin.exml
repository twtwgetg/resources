	<e:TextInput id="maxdis" width="181" height="31" x="498.01" y="427.67" anchorOffsetX="0" anchorOffsetY="0"/>
	<e:Group id="collecionUI" y="834" horizontalCenter="1" width="316">
		<e:Image width="260" height="15" y="0" x="17" source="com_barbg" scale9Grid="7,0,99,15"/>
		<e:Image id="foreg" scaleX="1" scaleY="1" width="256" fillMode="clip" x="17" source="com_bar2"/>
		<e:Image width="49" height="15" y="0" x="47" source="com_barbg1" scaleX="-1"/>
		<e:Image width="49" height="15" y="0" x="244" source="com_barbg1"/>
		<e:Label id="collectName" text="唤醒中" x="17" y="-22" size="18" stroke="1" width="260" anchorOffsetY="0" height="18" fontFamily="Microsoft YaHei" textColor="0xf2f2e9" strokeColor="0x14181b" textAlign="center"/>
		<e:Label id="timeLbl" text="0%" size="16" stroke="1" textAlign="center" width="52" fontFamily="Microsoft YaHei" textColor="0xf2f2e9" strokeColor="0x14181b" y="-2" x="123"/>
	</e:Group>
	<e:Group id="dazuo" x="175" y="616" touchEnabled="false" anchorOffsetY="0" height="230" anchorOffsetX="0" width="450">
		<e:Group x="40" y="0" touchEnabled="false">
			<e:Button id="btnYaoQing" label="" x="54" y="2" width="119" height="119">
				<e:skinName>
				<e:Skin states="up,down,disabled" xmlns:ogre_ui="ogre_ui.*">
					<e:Image width="100%" height="100%" y.down="-1" source="DaZuo_but01" source.up="DaZuo_but01" source.down="DaZuo_but01"/>
