		<e:Image width="50%" height="50%" scaleX="-1" scaleY="-1" source="com_back_down" anchorOffsetX="0" anchorOffsetY="0" scale9Grid="40,40,5,5"  bottom="0" right="0"/>
	</e:Group>
	<e:Scroller id="scrListChat" anchorOffsetX="0" anchorOffsetY="0" width="576" x="103" height="787" y="114">
