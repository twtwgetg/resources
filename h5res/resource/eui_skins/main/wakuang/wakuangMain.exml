		<e:Label text="拓印技能" y="50" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0x1CE17D" scaleX="1" scaleY="1"/>
		</e:Group>
