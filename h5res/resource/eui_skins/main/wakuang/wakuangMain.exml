		<e:Label text="，便可以通过" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF" scaleX="1" scaleY="1"/>
		<e:Label text="进入下一层" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="216" textColor="0xFFFFFF" scaleX="1" scaleY="1"/>
		</e:Group>
		<e:Label text="如果本层还有想要探索的地方，建议先探索完成后，再进入下一层" y="245.46" width="517" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" left="49" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
		<e:Group x="50" y="298.43" height="50">
		<e:Label text="所有层数" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="142.65" textColor="0x1CE17D"/>
		<e:Label text="每个秘境通关" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF"/>
		<e:Label text="后可再次挑战，也可以挑" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="241.33" textColor="0xFFFFFF"/>
		<e:Label text="战下一个秘境，新开启的秘境奖励会更好" y="26" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF"/>
		</e:Group>
		<e:Label text="3.事件：" y="357.92" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" left="50" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
		<e:Label text="挖掘时，会遇到各种事件：" y="383.57" width="517" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" left="49" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
		<e:Group x="50" y="410.57" height="127" anchorOffsetY="0">
		<e:Label text="秘境守护：" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" width="505" textColor="0x1CE17D"/>
		<e:Label text="秘境守护看守着附近的石板，击败他才可" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="90" textColor="0xFFFFFF"/>
		<e:Label text="以挖掘这些石板" y="25" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF"/>
		<e:Label text="侠士：" y="50" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0x1CE17D" width="505"/>
		<e:Label text="侠士会提出一些条件，满足后可获得奖励" y="50" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="65" textColor="0xFFFFFF"/>
		<e:Label text="宝箱：" y="75" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0x1CE17D" width="505"/>
		<e:Label text="每次开启都可以获得里面的一样奖励，总" y="75" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="65" textColor="0xFFFFFF"/>
		<e:Label text="共最多可以开启8次" y="101" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF"/>
		</e:Group>
		<e:Label text="4.拓印技能：" y="549.66" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" left="49" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
		<e:Group x="49" y="578.66">
		<e:Label text="探索中可以收集到各种拓印，拓印收集到足够数量后便可以使用对应的" y="0" width="506" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF" x="0"/>
		<e:Label text="了，合理地运用" y="24" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF" x="337"/>
		<e:Label text="，可以使你的探索更加轻松" y="50" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF" x="97"/>
