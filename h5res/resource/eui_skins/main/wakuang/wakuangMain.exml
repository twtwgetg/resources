		<e:Label text="，找到钥匙后" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="362" textColor="0xFFFFFF"/>
		<e:Label text="明亮的石板" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="47.67" textColor="0x1CE17D"/>
