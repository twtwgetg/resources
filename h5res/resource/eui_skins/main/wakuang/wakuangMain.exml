		</e:Group>
		<e:Group x="50" y="125">
		<e:Label text="达到上限后，不再恢复" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="3" textColor="0xFFFFFF"/>
		</e:Group>
