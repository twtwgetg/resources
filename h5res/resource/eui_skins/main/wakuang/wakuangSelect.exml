		<e:Label text="挖掘时，会遇到各种事件：" y="383.57" width="517" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" scaleX="1" scaleY="1" left="49" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
