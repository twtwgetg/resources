		<e:Label text="1.玩法限制：" y="65" anchorOffsetY="0" strokeColor="0x14181B" size="24" anchorOffsetX="0" left="50" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
		<e:Group x="50" y="95">
		<e:Label text="每" y="0" anchorOffsetY="0" strokeColor="0x14181B" size="24" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="0" textColor="0xFFFFFF"/>
		<e:Label text="恢复1点体力，体力最多只能保存" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" x="93.98" fontFamily="Microsoft YaHei" stroke="1" textColor="0xFFFFFF"/>
			<e:Label text="60点" y="0" anchorOffsetY="0" size="24" strokeColor="0x14181B" anchorOffsetX="0" fontFamily="Microsoft YaHei" stroke="1" x="445.84" textColor="0x1CE17D"/>
