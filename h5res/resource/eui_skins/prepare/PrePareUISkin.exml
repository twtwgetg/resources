	<e:Group id="group1" x="185" y="803" visible="false">
		<e:Image x="0" y="0" anchorOffsetX="0" anchorOffsetY="0" scale9Grid="18,15,33,85" source="XunBao_011"/>
		<e:Image x="116" y="0" anchorOffsetX="0" anchorOffsetY="0" scale9Grid="18,15,33,85" scaleX="-1" source="XunBao_011"/>
